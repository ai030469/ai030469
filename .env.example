# Backend
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (optional - defaults to ./backend/data/events.db)
DB_PATH=./backend/data/events.db

# Google Sheets Integration (optional)
# Create a Service Account at https://console.cloud.google.com
# Enable Google Sheets API, download JSON credentials
# Paste the entire JSON as a single-line string:
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Your Google Spreadsheet ID (from the URL)
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here
